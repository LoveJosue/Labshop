<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Labstore - Notification</title>
  <style>
    /* Quelques styles de secours pour les clients modernes */
    body {
      margin: 0;
      padding: 0;
      background-color: #f7f7f7;
      font-family: 'Poppins', Arial, sans-serif;
      color: #333;
    }
    a {
      color: #000;
      text-decoration: none;
    }
    img {
      border: none;
      display: block;
      outline: none;
      text-decoration: none;
    }
    table {
      border-collapse: collapse;
    }

    /* Empêche Outlook d'ajouter des marges inutiles */
    .ExternalClass {
      width: 100%;
    }
    .ExternalClass,
    .ExternalClass p,
    .ExternalClass span,
    .ExternalClass font,
    .ExternalClass td,
    .ExternalClass div {
      line-height: 100%;
    }

    /* Outlook.com et Gmail padding reset */
    table td {
      border-collapse: collapse;
    }

    /* Support mobile (certains clients respectent les media queries) */
    @media only screen and (max-width: 600px) {
      table[class="container"] {
        width: 100% !important;
      }
      td[class="responsive-center"] {
        text-align: center !important;
        display: block !important;
        width: 100% !important;
      }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#f7f7f7;">

  <!-- WRAPPER PRINCIPAL -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f7f7f7;padding:30px 0;">
    <tr>
      <td align="center">
        
        <!-- CONTENEUR PRINCIPAL -->
        <table class="container" width="600" cellpadding="0" cellspacing="0" border="0" style="background:#ffffff;border:1px solid #e4e4e4;border-radius:4px;">
          
          <!-- HEADER -->
          <tr>
            <td align="center" style="padding:20px 20px 10px 20px;">
              {{!-- <img src="https://labstore.tg/logo.png" width="120" height="40" alt="Labstore"> --}}
            </td>
          </tr>

          <!-- CONTENU DYNAMIQUE -->
          <tr>
            <td style="padding:0;">
              {{{ body }}}
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td align="center" style="background:#111;padding:30px 20px;color:#ddd;text-align:center;">
              <p style="font-size:20px;font-weight:700;color:#fff;margin:0 0 6px 0;">Labstore</p>
              <p style="max-width:360px;margin:auto;font-size:14px;line-height:1.5;color:#aaa;">
                Votre boutique en ligne pour les produits de qualité, livrés rapidement.
              </p>

              <hr style="border:0;border-top:1px solid #444;width:80%;margin:20px auto;">

              <p style="font-size:14px;margin:0;color:#ccc;">Adresse : Lomé, TG</p>
              <p style="font-size:14px;margin:0;color:#ccc;text-decoration:none;">Téléphone : +228 90 08 85 22</p>

              <p style="margin:18px 0 0 0;font-size:14px;">
                <a href="https://labstore.tg" style="color:#fff;text-decoration:none;">Visiter le site</a> ·
                <a href="https://labstore.tg/faq" style="color:#fff;text-decoration:none;">FAQ / Aide</a>
              </p>

              <hr style="border:0;border-top:1px solid #444;width:80%;margin:20px auto;">

              <p style="font-size:12px;color:#777;line-height:1.4;margin:0;">
                © {{ getLocalYear }} Labstore. Tous droits réservés.<br>
                <a href="https://labstore.tg/conditions" style="color:#ccc;text-decoration:none;">Conditions générales</a> ·
                <a href="https://labstore.tg/confidentialite" style="color:#ccc;text-decoration:none;">Politique de confidentialité</a>
              </p>
            </td>
          </tr>
        </table>
        <!-- FIN DU CONTENEUR PRINCIPAL -->

      </td>
    </tr>
  </table>
</body>
</html>
